# SENECIO ORACLE — .dockerignore
# Exclude anything that shouldn't enter the image

# Python caches
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual envs
.venv/
venv/
env/

# Local audit (runtime generates its own)
senecio_polymarket/data/audit/*.jsonl

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
/tmp/

# Test scripts (don't need in production)
senecio_polymarket/scripts/test_run.py
senecio_polymarket/scripts/run.sh

# Dockerfile companions
Dockerfile
.dockerignore

# Docs (not needed at runtime)
README.md

# NOTE: senecio_output/ is INCLUDED — it seeds predictions.jsonl for the oracle
# Do NOT exclude it.
